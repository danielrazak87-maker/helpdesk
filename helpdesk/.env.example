# ════════════════════════════════════════════════════════════════════
# KF Helpdesk — Environment Configuration
# ════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# All settings are validated on startup — missing required values
# will produce clear error messages and exit.
# ════════════════════════════════════════════════════════════════════

# ─── Required ──────────────────────────────────────────────────────

# ⚠️ REQUIRED: Generate a strong random key for production
#   python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-very-secret-key-change-this

# Flask environment: 'development' or 'production'
# In production, secure cookies and certain security features activate.
FLASK_ENV=development

# ⚠️ REQUIRED: Database connection string
# PostgreSQL (production):
# DATABASE_URL=postgresql+pg8000://user:password@localhost:5432/helpdesk_db
# SQLite (development):
DATABASE_URL=sqlite:///helpdesk.db

# ─── Mail / SMTP (optional — needed for password resets & notifications) ──
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=Helpdesk <noreply@helpdesk.com>

# ─── Admin Seed (first-run only) ─────────────────────────────────────
# These are used to create the initial admin account on first launch.
# Remove or change ADMIN_PASSWORD after seeding for security.
ADMIN_EMAIL=admin@helpdesk.com
ADMIN_PASSWORD=Admin@1234

# ─── Rate Limiting ──────────────────────────────────────────────────
# Set RATELIMIT_ENABLED=False to disable rate limiting entirely.
# RATELIMIT_DEFAULT controls the default per-IP rate limit.
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100/minute
# For distributed deployments (e.g., multiple workers):
# RATELIMIT_STORAGE_URL=redis://localhost:6379/0
